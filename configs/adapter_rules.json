{
  "HDF5": {
    "length_reference_key": "action"
  },
  "ROS": {
    "extra_options": {
      "ignore_topics": ["depth", "compressed"]
    }
  },
  "ZhiPingFang": {
    "base_type": "HDF5", 
    "match_rules": {
      "path_keywords": ["智平方", "ZhiPingFang"],
      "file_extensions": [".h5", ".hdf5"]
    },
    "length_reference_key": "observations/timestamp",
    "image_keys_map": {
      "cam_chest": "observations/camera/rgb/chest/images",
      "cam_left": "observations/camera/rgb/left/images"
    },
    "state_keys_map": {
      "qpos_left_arm": "observations/arm/left/joints"
    }
  }
}