{
  "HDF5": {
    "length_reference_key": "action",
    "image_keys_map": {
      "main_cam": "observations/images"
    },
    "state_keys_map": {
      "qpos": "qpos",
      "action": "action"
    },
    "extra_options": {}
  },
  "ROS": {
    "image_topic_keywords": ["image", "rgb", "cam"],
    "ignore_topics": ["depth", "compressed"]
  },
  "LeRobot": {
    "default_version": "v2.1"
  },
  "Unitree": {
    "qpos_keys": ["left_arm", "right_arm", "head"]
  },
  "RawFolder": {
    "image_extensions": [".jpg", ".png", ".jpeg"]
  },
  "ZhiPingFang": {
    "length_reference_key": "observations/timestamp",
    "image_keys_map": {
      "cam_chest": "observations/camera/rgb/chest/images",
      "cam_head": "observations/camera/rgb/head/images",
      "cam_left": "observations/camera/rgb/left/images",
      "cam_right": "observations/camera/rgb/right/images"
    },
    "state_keys_map": {
      "qpos_left_arm": "observations/arm/left/joints",
      "qpos_right_arm": "observations/arm/right/joints",
      "gripper_left": "observations/effector/left/position",
      "gripper_right": "observations/effector/right/position",
      "chassis_pose": "observations/chassis/pose",
      "chassis_vel": "observations/chassis/vel",
      "torso_joints": "observations/torso/joints",
      "neck_joints": "observations/neck/joints"
    },
    "extra_options": {
      "image_dtype": "object"
    }
  }
}