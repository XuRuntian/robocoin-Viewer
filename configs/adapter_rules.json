{
  "_instruction": "此配置文件用于动态适配不同格式的机器人数据集。带 'Example_' 前缀的项为教学示例，不会被系统实际执行。编写实际规则时，请参考这些示例。",

  "HDF5": {
    "length_reference_key": "action"
  },
  "ROS": {
    "extra_options": {
      "ignore_topics": ["depth", "compressed"]
    }
  },

  "Example_ROS_Custom": {
    "_comment": "【示例】自定义 ROS 数据包解析规则，将底层的复杂 Topic 映射为简单的标准名称",
    "base_type": "ROS",
    "match_rules": {
      "path_keywords": ["CustomRobot", "test_bag"],
      "file_extensions": [".mcap", ".bag"]
    },
    "image_keys_map": {
      "cam_front": "/camera_front/color/image_raw",
      "cam_wrist": "/camera_wrist/color/image_raw"
    }
  },

  "umi_dual_arm": {
      "base_type": "DASMCAP",
      "cameras": {
          "/robot0/sensor/camera0/compressed": "left_wrist_cam",
          "/robot1/sensor/camera0/compressed": "right_wrist_cam"
      },
      "arm_groups": {
          "left": {
              "pose_topic": "/robot0/vio/eef_pose",
              "gripper_topic": "/robot0/sensor/magnetic_encoder"
          },
          "right": {
              "pose_topic": "/robot1/vio/eef_pose", 
              "gripper_topic": "/robot1/sensor/magnetic_encoder" 
          }
      },
      "base": null 
    },
    
  "ZhiPingFang": {
    "base_type": "HDF5", 
    "length_reference_key": "observations/arm/left/joints",
    "cameras": {
      "cam_head": "observations/camera/rgb/chest/images",
      "cam_right": "observations/camera/rgb/left/images",
      "cam_left": "observations/camera/rgb/left/images",
      "cam_chest": "observations/camera/rgb/chest/images"
    },
    "arm_groups": {
      "left": {
        "qpos": "observations/arm/left/joints"
      },
      "right": {
        "qpos": "observations/arm/right/joints"
      }
    }
  }
}
